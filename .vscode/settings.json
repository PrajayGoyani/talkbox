{
  "files.eol": "\n",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.watcherExclude": {
    "bun.lock": true
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "editor.formatOnSave": true,
  "oxc.enable.oxfmt": true,
  "oxc.enable.oxlint": true,
  "oxc.configPath": "./oxlint.json",
  "oxc.fmt.configPath": "./oxfmt.json",
  "search.exclude": {
    "bun.lock": true
  },
  "tailwindCSS.classFunctions": ["cn", "cva"],
  "tailwindCSS.experimental.classRegex": [
    ["class:\\s*?[\"'`]([^\"'`]*).*?,"],
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "typescript.experimental.useTsgo": true,
  "typescript.native-preview.tsdk": "/home/dev/Documents/work/other/projects/user-chat/node_modules/@typescript/native-preview",
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
