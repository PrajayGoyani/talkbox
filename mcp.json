{
  "mcpServers": {
    "code-review-graph": {
      "command": "uvx",
      "args": ["code-review-graph", "serve"],
      "type": "stdio"
    },
    "graphify": {
      "command": "uv",
      "args": ["run", "--with", "graphifyy", "--with", "mcp", "-m", "graphify.serve", "graphify-out/graph.json"],
      "type": "stdio"
    },
    "svelte": {
      "command": "bunx",
      "args": ["@sveltejs/mcp@0.1.22"],
      "type": "stdio"
    }
  }
}
