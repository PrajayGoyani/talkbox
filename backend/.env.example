APP_NAME=user-chat
BASE_URL=http://localhost:3000

# NOTE: 
# NODE_ENV will be overide if bootstarp by "make commands {up, down, restart}"
# using pm2 process manager for that checkout "Makefile", "ecosystem.config.cjs"
# use "NODE_ENV=production" due to cookie issue on render deploy
NODE_ENV=development # development, production
PORT=3000

MONGO_URI=mongodb://localhost:27017/user-chat

JWT_SECRET_KEY=your_jwt_secret
JWT_EXPIRATION=5h
JWT_REFRESH_SECRET_KEY=your_refresh_jwt_secret
JWT_REFRESH_EXPIRATION=7d

BCRYPT_SALT=10

ALLOWED_ORIGINS=http://localhost:5173

NODE_VERSION=24.14.0 # for deploying on render

CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@dpfx5wjtg
UPLOAD_STRATEGY=local # Options: local, cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Jobs & Seeding
ENABLE_JOBS=false
DEBUG_JOBS=false
DEMO_PASSWORD=password123

# Feature Limits & Retention
REACTIONS_MAX_UNIQUE=20
FREE_PLAN_SCRUB_DAYS=7
FREE_PLAN_CHAT_LIMIT=5
PRO_PLAN_SESSION_LIMIT=5
RETENTION_MESSAGE_DAYS=365
RETENTION_DELETED_CHAT_DAYS=14
RETENTION_NOTIFICATION_DAYS=30
MESSAGE_MODIFY_LIMIT_HOURS=1

# Cookie Logic
COOKIE_SAMESITE=lax # use 'none' for cross-site with HTTPS
COOKIE_SECURE=false # set 'true' if using HTTPS

REDIS_URL="rediss://"

SENTRY_DSN=""

# Email / SMTP (optional — email features disabled if not configured)
# For dev testing, use https://ethereal.email or https://mailtrap.io
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@talkbox.app
FRONTEND_URL=http://localhost:5173
RESET_TOKEN_TTL=3600    # 1 hour
VERIFY_TOKEN_TTL=86400  # 24 hours