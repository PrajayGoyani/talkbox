{
  "name": "user-chat",
  "private": true,
  "workspaces": [
    "workspaces/apps/*",
    "workspaces/packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "bun run --cwd workspaces/apps/backend build",
    "build:frontend": "bun run --cwd workspaces/apps/frontend build",
    "check": "vp run check:all",
    "fmt": "vp run fmt:all"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "^0.1.22",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "resolutions": {
    "cloudinary": "^2.10.0",
    "vite": "$vite"
  },
  "overrides": {
    "cloudinary": "^2.10.0",
    "vite": "$vite"
  },
  "packageManager": "bun@1.3.14"
}
