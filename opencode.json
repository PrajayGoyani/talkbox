{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "code-review-graph": {
      "type": "local",
      "command": ["uvx", "code-review-graph", "serve"],
      "enabled": true,
      "timeout": 60000
    },
    "graphify": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--with",
        "graphifyy",
        "--with",
        "mcp",
        "-m",
        "graphify.serve",
        "graphify-out/graph.json"
      ]
    },
    "svelte": {
      "type": "remote",
      "url": "https://mcp.svelte.dev/mcp"
    }
  }
}
