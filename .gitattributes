# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly set line endings for specific file types
*.js text eol=lf
*.ts text eol=lf
*.svelte text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Mark binary files to prevent line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
